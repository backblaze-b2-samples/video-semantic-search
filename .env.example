# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=us-west-004

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_APPLICATION_KEY_ID=000000000example00000000a
# B2_APPLICATION_KEY=EXAMPLEonlyFAKEapplicationKEYvalue
# B2_BUCKET_NAME=my-video-search-bucket
# B2_REGION=us-west-004

# --- AI providers (video pipeline) ---
# Leave both blank to run with the generic B2 features only (upload, files,
# dashboard). Video ingest/transcription/search will surface a clear
# "configure provider" state instead of crashing.
#
# OPENAI_API_KEY  — Whisper transcription + text embeddings.
# ANTHROPIC_API_KEY — optional; powers the synthesized answer over clips.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional knobs (defaults live in services/api/app/config/settings.py) ---
# TRANSCRIPTION_PROVIDER=openai          # openai | local (faster-whisper)
# EMBEDDING_MODEL=text-embedding-3-small
# ANSWER_MODEL=claude-sonnet-4-6
# VIDEO_PREFIX=video-semantic-search/
# MAX_VIDEO_SIZE=5368709120              # 5 GiB
